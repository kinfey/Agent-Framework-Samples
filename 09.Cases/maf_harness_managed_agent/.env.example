# ── MAF Harness Managed Agent — Environment Variables ─────────────────────────
# Copy to .env and fill in your values.
# python-dotenv will load it automatically if you call load_dotenv() in main.py.

# ── Microsoft Foundry (required) ──────────────────────────────────────────────
FOUNDRY_PROJECT_ENDPOINT=https://<your-hub>.services.ai.azure.com
FOUNDRY_MODEL=gpt-5.4

# ── Auth: choose ONE of the following ────────────────────────────────────────
# Option A — API key (dev / CI)
# FOUNDRY_API_KEY=<your-foundry-api-key>

# Option B — Azure CLI (local dev)
# Run:  az login
# DefaultAzureCredential will pick it up automatically.

# Option C — Managed Identity (Azure production)
# No env var needed — DefaultAzureCredential handles it automatically.

# ── Agent settings (optional) ─────────────────────────────────────────────────
AGENT_NAME=ManagedAgent
MAX_ITERATIONS=20
